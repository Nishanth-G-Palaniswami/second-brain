# Integration secrets — copy to `.env` and fill in. `.env` is gitignored.
# Real values never flow to the LLM — they're read only by integration modules
# inside .claude/scripts/integrations/.

# ---------------------------------------------------------------------------
# Vault location and timezone
# ---------------------------------------------------------------------------
# Absolute path to the directory holding your second-brain markdown files
# (SOUL.md, USER.md, MEMORY.md, daily/, drafts/, etc.). All skills and scripts
# read from this root. Defaults to ~/second-brain-vault if unset.
SECOND_BRAIN_VAULT=

# IANA timezone — used for dated filenames in skills (e.g. America/New_York,
# Europe/London, Asia/Kolkata). Defaults to the OS clock if unset.
USER_TIMEZONE=

# ---------------------------------------------------------------------------
# Slack (Phase 4b)
# ---------------------------------------------------------------------------
# Create a Slack App at https://api.slack.com/apps → From scratch.
#
# Bot Token Scopes (OAuth & Permissions → Scopes):
#   channels:history, groups:history, im:history, mpim:history,
#   users:read, chat:write
# Install to workspace; copy the Bot User OAuth Token (starts with xoxb-).
SLACK_BOT_TOKEN=xoxb-...

# Your own Slack user id (click your profile → ⋮ → Copy member ID). Used to
# detect @-mentions in channel history and to ignore your own messages.
SLACK_USER_ID=U...

# User Token — required for the slack-dm-digest skill (reading DMs between you
# and other humans). The bot token above can only see DMs addressed to the bot
# itself; private DMs between two users are not visible to any bot.
#
# User Token Scopes (OAuth & Permissions → Scopes → User Token Scopes):
#   im:read, im:history, mpim:read, mpim:history, users:read
#   channels:read, channels:history, groups:read, groups:history
# (first line = DMs only; add the second line's scopes to enable slack-channel-digest)
# Reinstall the app after adding user scopes; copy the User OAuth Token
# (starts with xoxp-). Read-only — never grant *:write on the user token.
# SLACK_USER_TOKEN=xoxp-...

# Optional — only needed in Phase 7 (Socket Mode chat bot). Not used by 4b.
# App-Level Token with `connections:write` scope (xapp-...).
# SLACK_APP_TOKEN=xapp-...

# ---------------------------------------------------------------------------
# GitHub (Phase 4c)
# ---------------------------------------------------------------------------
# Fine-grained PAT scoped to the repos in USER.md → Active Repos.
# Permissions: Contents:Read, Metadata:Read, Pull requests:Read, Issues:Read.
# GITHUB_TOKEN=github_pat_...
